{
  "metadata": {
    "eval": "caregiver_state_legibility_v0",
    "privacy": "synthetic",
    "purpose": "Synthetic proxy tasks for whether a caregiver/operator can identify Parker review-state buckets and safe next actions from the local review surface.",
    "caveat": "Not a caregiver usability study, not human-graded evidence, and no private family data."
  },
  "tasks": [
    {
      "task_id": "csl-001-pending-confirmation",
      "title": "Identify a staged reminder waiting for patient confirmation",
      "privacy": "synthetic",
      "state_bucket": "pending_actions",
      "prompt": "Which local action is still waiting for confirmation, and what can the caregiver safely do next?",
      "expected_answer": {
        "bucket": "pending_actions",
        "status": "staged",
        "allowed_actions": ["confirm", "cancel"],
        "forbidden_actions_absent": ["send_external", "approve_outbox"],
        "local_only": true,
        "review_only": false,
        "provenance_fields": ["subject", "action_type", "status"],
        "safety_critical": true
      },
      "system_observations": {
        "parker_review_ui": {
          "bucket": "pending_actions",
          "status": "staged",
          "allowed_actions": ["confirm", "cancel"],
          "forbidden_actions_present": [],
          "local_only": true,
          "review_only": false,
          "provenance_fields": ["subject", "action_type", "status", "created_at"],
          "visible_summary": "Reminder: water tomato plants — staged; confirm or cancel before execution."
        },
        "raw_chat_only": {
          "bucket": "unknown",
          "status": "unknown",
          "allowed_actions": [],
          "forbidden_actions_present": [],
          "local_only": false,
          "review_only": false,
          "provenance_fields": [],
          "visible_summary": "Transcript says: remind me to water tomato plants."
        }
      }
    },
    {
