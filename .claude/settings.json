{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/git-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking git command against shared-checkout rules"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-git-status.sh\"",
            "timeout": 20,
            "statusMessage": "Reading shared-checkout git state"
          }
        ]
      }
    ]
  }
}
