{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Parker",
  "version": "0.3.0",
  "identifier": "app.parker.desktop",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "resources": {
      "../../backend/dist/parker": "engine"
    },
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
