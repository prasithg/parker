# Parker v0 — environment variables
#
# Copy to backend/.env and fill in the values you need.
# Most settings have safe defaults — the zero-config demo works with an
# empty file. Variables marked [REQUIRED FOR X] enable specific features.
#
# pydantic-settings reads backend/.env automatically when the server or
# any make target runs from the backend/ directory.

# ---------------------------------------------------------------------------
# Patient identity
# Used in Parker's spoken identity and escalation context.
# ---------------------------------------------------------------------------
PATIENT_NAME=Dad

# ---------------------------------------------------------------------------
# Anthropic  [REQUIRED FOR model-enhanced repair choices]
# When set, ambiguous utterances get contextually specific repair choices
# from claude-haiku rather than the generic "set a reminder / send a message"
# fallback. The demo and all tests work without this key.
#
# Get a key at: https://console.anthropic.com
# ---------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Dashboard auth  [RECOMMENDED for LAN pilot]
# Locks the caregiver decision surface (/parker/review, /parker/outbox,
# action confirm/execute/cancel) behind HTTP Basic. Leave DASHBOARD_PASSWORD
# empty (the default) for credential-free localhost demos.
# ---------------------------------------------------------------------------
DASHBOARD_USERNAME=family
# DASHBOARD_PASSWORD=choose-a-passphrase

# ---------------------------------------------------------------------------
# Parker non-response escalation thresholds
# An unconfirmed action resurfaced RESURFACE_THRESHOLD times without a
# response, and last resurfaced >= QUIET_MINUTES ago, becomes an escalation
# candidate visible on the review page.
# ---------------------------------------------------------------------------
PARKER_NON_RESPONSE_RESURFACE_THRESHOLD=3
PARKER_NON_RESPONSE_QUIET_MINUTES=30

# ---------------------------------------------------------------------------
# Database  [rarely needed]
# Default is backend/parker.db (SQLite, relative to the backend/ directory).
# Change only if you need a different path.
# ---------------------------------------------------------------------------
# DATABASE_URL=sqlite:///./parker.db

# ---------------------------------------------------------------------------
# Twilio  [NOT USED in v0 — legacy from prior prototype]
# The v0 codebase has no outbound call or SMS path. Leave these empty.
# ---------------------------------------------------------------------------
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ---------------------------------------------------------------------------
# OpenAI  [NOT USED in v0 text/voice demo path]
# The realtime agent module exists but is not wired into the demo or capture
# pipeline. Leave empty for the LAN pilot.
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# ElevenLabs voice cloning  [OPTIONAL, consent-gated, not part of v0 product]
# Voice cloning requires explicit family consent. Set VOICE_CLONE_CONSENTED=true
# only after recording informed consent from all family members involved.
# Parker's identity and behaviour do NOT depend on this.
# ---------------------------------------------------------------------------
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# VOICE_CLONE_CONSENTED=false
